# 0G Chain Testnet Configuration
# Network Name: 0G-Galileo-Testnet
# Chain ID: 16602
# RPC: Copy from spec or use http://178.238.236.119:6789
ZG_CHAIN_RPC_URL=http://178.238.236.119:6789
KEEPER_PRIVATE_KEY=0x...

# Contract Addresses (copy from packages/contracts/deployments.json after deployment)
FORO_REGISTRY_ADDRESS=
AGENT_VAULT_ADDRESS=
MOCK_ERC8004_ADDRESS=

# 0G Compute Configuration (Router API with TEE Verification)
# Get your API key from https://pc.0g.ai
ZG_COMPUTE_ENDPOINT=https://router-api.0g.ai/v1/chat/completions
ZG_COMPUTE_AUTH_TOKEN=sk-your-api-key-here
ZG_COMPUTE_MODEL=zai-org/GLM-5-FP8
ZG_COMPUTE_ENABLED=true

# Keeper Configuration
MIN_STAKE_ETH=0.01  # Minimum stake to register as Keeper
MAX_CONCURRENT_JOBS=5  # Maximum parallel test executions
TIMEOUT_SECONDS=300  # Agent endpoint timeout (5 minutes)
REVEAL_TIMEOUT_SECONDS=3600  # Default reveal timeout (1 hour, overridden by test request)
POLL_INTERVAL_MS=10000  # Event polling interval (10 seconds)
FORFEIT_CHECK_INTERVAL_MS=60000  # Check for expired reveals every minute

# Logging
LOG_LEVEL=info  # Options: error, warn, info, debug
NODE_ENV=development  # Options: development, production

# Mock Agent Configuration
MOCK_AGENT_PORT=3001
MOCK_AGENT_URL=http://localhost:3001/summarize
MOCK_AGENT_LATENCY_MS=500  # Artificial latency for realistic testing
