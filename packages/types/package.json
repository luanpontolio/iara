{
  "name": "@foro/types",
  "version": "0.1.0",
  "private": true,
  "description": "Shared TypeScript types for Foro",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./agent": "./dist/agent.js",
    "./keeper": "./dist/keeper.js",
    "./contracts": "./dist/contracts.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "clean": "rm -rf dist",
    "generate-types": "tsx scripts/generate-types.ts",
    "generate-typechain": "typechain --target ethers-v6 --out-dir src/contracts '../contracts/out/**/*.json'"
  },
  "dependencies": {
    "ethers": "^6.11.0"
  },
  "devDependencies": {
    "@typechain/ethers-v6": "^0.5.1",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.1",
    "@typescript-eslint/parser": "^6.19.1",
    "eslint": "^8.56.0",
    "prettier": "^3.2.4",
    "typechain": "^8.3.2",
    "typescript": "^5.3.3"
  }
}
